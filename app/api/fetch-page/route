import { NextRequest, NextResponse } from 'next/server'

export const runtime = 'edge'
export const maxDuration = 60

export async function POST(req: NextRequest) {
  try {
    const body = await req.json() as { url?: string; pageContent?: string; fetchMethod?: string }
    const { url, pageContent } = body

    if (!url) {
      return NextResponse.json({ error: 'No URL provided' }, { status: 400 })
    }

    const apiKey = process.env.ANTHROPIC_API_KEY
    if (!apiKey) {
      return NextResponse.json({ error: 'ANTHROPIC_API_KEY not configured' }, { status: 500 })
    }

    const prompt = `You are a world-class CRO strategist. Audit this website: ${url}

Page content:
---
${(pageContent || 'No content available.').slice(0, 8000)}
---

Read top to bottom like a human. Name each section descriptively. Return ONLY raw JSON, no markdown, no code fences.

{"scores":{"conversion":54,"ux":71,"cta":43,"trust":61,"mobile":68},"score_notes":{"conversion":"Weak value prop","ux":"Decent but cluttered","cta":"Learn More too weak","trust":"No social proof above fold","mobile":"CTA below fold"},"sections":[{"name":"Hero Section","score":48,"what_we_found":"The headline is vague. CTA says Learn More.","issues":[{"severity":"high","what":"Headline lacks outcome clarity","why":"Visitors cannot understand the transformation in 3 seconds","fix":"Lead with a specific outcome e.g. Get 3x More Leads Without Changing Your Product"}],"copy_rewrite":{"label":"Hero Headline","original":"Welcome to our platform","improved":"Get 3x More Leads. Starting Today."}}],"overall_issues":[{"severity":"high","title":"No social proof above fold","description":"Cold visitors see zero trust signals in the first viewport.","fix":"Add a logo bar directly below the hero CTA"}],"copy":{"headline":{"original":"Welcome to our platform","improved":"Get Results Faster. Starting Today."},"subheadline":{"original":"We help businesses grow","improved":"Join 2,000 companies who cut onboarding time by 60%"},"cta":{"original":"Learn More","improved":"Start Free — No Credit Card"},"benefits":{"original":"Fast, easy, powerful","improved":"Ship in hours not weeks. Save 10hrs per week."}},"recommendations":[{"icon":"zap","title":"Add urgency to your CTA","description":"Current CTA has no urgency. Add a benefit and friction reducer below it.","impact":"high"},{"icon":"shield","title":"Add trust signals above fold","description":"No logos or reviews visible without scrolling. Cold traffic needs trust immediately.","impact":"high"},{"icon":"target","title":"Clarify your value proposition","description":"Visitors cannot articulate what you do after 5 seconds.","impact":"high"},{"icon":"users","title":"Add specific testimonials","description":"Generic praise does not convert. Add quotes with full names and specific results.","impact":"medium"},{"icon":"eye","title":"Reduce cognitive load","description":"Too many competing messages. One headline, one subheadline, one CTA.","impact":"medium"},{"icon":"trending","title":"Add a risk reverser","description":"Below CTA add: No credit card required, Cancel anytime, Free for 14 days.","impact":"medium"}],"layout":[{"title":"Move social proof to position 2","description":"Place a trusted-by logo row immediately after the hero."},{"title":"Add a CTA after every 2 sections","description":"Do not make visitors scroll back to convert."},{"title":"Left-align all body copy","description":"Centre-aligned body text reads poorly beyond 2 lines."},{"title":"Compress the hero section","description":"Reduce hero height so value is visible before scrolling."},{"title":"Add a sticky mobile CTA bar","description":"Pin primary CTA to the bottom on mobile."}]}`

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5',
        max_tokens: 8000,
        messages: [{ role: 'user', content: prompt }],
      }),
    })

    if (!response.ok) {
      const errText = await response.text()
      return NextResponse.json({ error: 'Anthropic API error ' + response.status + ': ' + errText }, { status: 500 })
    }

    const data = await response.json() as { content: Array<{ type: string; text: string }> }
    const text = data.content?.[0]?.text || ''

    let clean = text.replace(/```json[\r\n]?/g, '').replace(/```[\r\n]?/g, '').trim()
    const start = clean.indexOf('{')
    const end = clean.lastIndexOf('}')
    if (start !== -1 && end !== -1) clean = clean.slice(start, end + 1)

    const result = JSON.parse(clean)
    return NextResponse.json({ ok: true, result })

  } catch (err: unknown) {
    const msg = err instanceof Error ? err.message : 'Unknown error'
    return NextResponse.json({ error: msg }, { status: 500 })
  }
}
