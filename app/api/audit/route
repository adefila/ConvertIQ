import { NextRequest, NextResponse } from 'next/server'

export const maxDuration = 60

export async function POST(req: NextRequest) {
  try {
    const body = await req.json() as { url?: string; pageContent?: string; fetchMethod?: string }
    const { url, pageContent, fetchMethod } = body

    if (!url) {
      return NextResponse.json({ error: 'No URL provided' }, { status: 400 })
    }

    const apiKey = process.env.ANTHROPIC_API_KEY
    if (!apiKey) {
      return NextResponse.json({ error: 'ANTHROPIC_API_KEY is not set in environment variables' }, { status: 500 })
    }

    const isCustomRewrite = fetchMethod === 'custom' && pageContent?.startsWith('CUSTOM_REWRITE:')
    const copyText = isCustomRewrite ? pageContent!.replace('CUSTOM_REWRITE:\n', '') : ''

    const prompt = isCustomRewrite
      ? `You are a world-class CRO copywriter. Rewrite this website copy to be outcome-focused, specific, and conversion-optimized for the site at ${url}. Return ONLY the rewritten copy, nothing else, no explanation:\n\n${copyText}`
      : `You are a world-class CRO (Conversion Rate Optimization) strategist. You have audited thousands of websites for YC startups and high-growth SaaS companies.

You are auditing: ${url}

Real page content extracted from the live website:
---
${(pageContent || 'No content fetched. Analyze based on the URL and domain knowledge.').slice(0, 9000)}
---

Read this page top to bottom like a human user would. Identify each distinct section. Give each a natural descriptive name based on what it contains (e.g. "Opening hero block", "Feature grid", "Social proof strip", "Pricing table", "FAQ", "Bottom CTA").

For each section evaluate:
1. CLARITY — understood in 3 seconds?
2. SPECIFICITY — real outcomes/numbers or vague buzzwords?
3. FRICTION — what objections does it create?
4. TRUST — builds or erodes credibility?
5. NEXT STEP — guides toward conversion?

Return ONLY a valid JSON object. No markdown. No code fences. No text before or after the JSON.

{"scores":{"conversion":54,"ux":71,"cta":43,"trust":61,"mobile":68},"score_notes":{"conversion":"Vague headline kills first impression","ux":"Clean layout but poor hierarchy","cta":"Learn More is too passive","trust":"No logos or reviews above fold","mobile":"CTA hidden below fold"},"sections":[{"name":"Hero Section","score":45,"what_we_found":"The headline reads: Welcome to Our Platform. The primary CTA button says Learn More. There is no subheadline explaining what the product does.","issues":[{"severity":"high","what":"Headline has zero outcome clarity","why":"A cold visitor cannot understand what transformation they get in 3 seconds. This directly increases bounce rate.","fix":"Replace with an outcome headline: e.g. Cut Your Onboarding Time by 60% — Without Changing Your Stack. Lead with the result, not the product."},{"severity":"high","what":"CTA says Learn More — the weakest possible action word","why":"Learn More signals hesitation and low commitment. It tells visitors nothing about what happens when they click.","fix":"Replace with Start Free Trial, Get My Free Audit, or See It In Action. Match the CTA to the specific next step."}],"copy_rewrite":{"label":"Hero Headline","original":"Welcome to Our Platform","improved":"Cut Onboarding Time by 60%. No Engineering Changes Required."}}],"overall_issues":[{"severity":"high","title":"No social proof visible above the fold","description":"Cold visitors see zero trust signals in the first viewport. This is the single biggest conversion killer for cold traffic.","fix":"Add a trusted-by logo row or review count directly below the hero CTA. Even 3 logos increases conversion significantly."},{"severity":"high","title":"Value proposition is unclear","description":"After reading the page for 5 seconds a visitor still cannot articulate what the product does or who it is for.","fix":"Add a one-sentence value prop below the headline: We help [target audience] achieve [outcome] without [obstacle]."}],"copy":{"headline":{"original":"Welcome to Our Platform","improved":"Cut Onboarding Time by 60%. No Engineering Changes Required."},"subheadline":{"original":"We help businesses achieve their goals","improved":"Join 2,000 SaaS teams who reduced churn by 40% in 90 days using automated onboarding flows."},"cta":{"original":"Learn More","improved":"Start Free — No Credit Card Required"},"benefits":{"original":"Fast, powerful, easy to use","improved":"Ship onboarding flows in hours not weeks. Reduce support tickets by 35%. Works with any stack in under 10 minutes."}},"recommendations":[{"icon":"zap","title":"Rewrite every CTA on the page","description":"Every instance of Learn More, Get Started, or Click Here should be replaced with specific action-outcome copy tied to your value prop.","impact":"high"},{"icon":"shield","title":"Add social proof in the first viewport","description":"Place customer logos or a review aggregate score immediately below the hero CTA. Cold traffic needs trust before they will click anything.","impact":"high"},{"icon":"target","title":"Add a one-sentence value proposition","description":"Visitors cannot articulate what you do after reading the page. Add a clear who-what-outcome sentence below your headline.","impact":"high"},{"icon":"users","title":"Replace generic testimonials with specific ones","description":"Quotes without names, companies, or specific results do not build trust. Add full attribution and quantified outcomes.","impact":"medium"},{"icon":"eye","title":"Reduce hero section text","description":"The hero has too many competing messages. Cut to one headline, one subheadline under 20 words, and one CTA.","impact":"medium"},{"icon":"trending","title":"Add friction reducers below every CTA","description":"Add micro-copy below each button: No credit card required, Cancel anytime, Free for 14 days. This alone lifts CTA clicks 10-25%.","impact":"medium"}],"layout":[{"title":"Move social proof to section 2","description":"Structure should be: Hero, then immediately a trust bar with logos or review count. This is the highest-impact structural change on the page."},{"title":"Place a CTA at the end of every 2 sections","description":"Do not make visitors scroll back to the top to convert. Add a contextual CTA button after the features section and after testimonials."},{"title":"Left-align all body copy","description":"Centre-aligned body text beyond 2 lines is harder to read. Left-align all paragraphs and feature descriptions."},{"title":"Compress the navigation","description":"Your nav has too many links which dilutes attention. Reduce to 3-4 items max and make the primary CTA the only highlighted element."},{"title":"Add a sticky CTA bar on mobile","description":"Pin your primary CTA to the bottom of the screen on mobile. Mobile visitors scroll past CTAs constantly. A sticky bar lifts mobile conversion by 20-40%."}]}`

    const anthropicRes = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5',
        max_tokens: isCustomRewrite ? 600 : 8000,
        messages: [{ role: 'user', content: prompt }],
      }),
    })

    if (!anthropicRes.ok) {
      const errBody = await anthropicRes.text()
      return NextResponse.json(
        { error: `Anthropic API returned ${anthropicRes.status}: ${errBody}` },
        { status: 500 }
      )
    }

    const anthropicData = await anthropicRes.json() as {
      content: Array<{ type: string; text: string }>
    }

    const text = anthropicData.content?.[0]?.text ?? ''

    if (isCustomRewrite) {
      return NextResponse.json({
        ok: true,
        result: {
          scores: { conversion: 0, ux: 0, cta: 0, trust: 0, mobile: 0 },
          score_notes: { conversion: '', ux: '', cta: '', trust: '', mobile: '' },
          sections: [],
          overall_issues: [],
          copy: {
            headline: { original: '', improved: text.trim() },
            subheadline: { original: '', improved: '' },
            cta: { original: '', improved: '' },
            benefits: { original: '', improved: '' },
          },
          recommendations: [],
          layout: [],
        },
      })
    }

    let clean = text.replace(/```json[\r\n]?/g, '').replace(/```[\r\n]?/g, '').trim()
    const start = clean.indexOf('{')
    const end = clean.lastIndexOf('}')
    if (start !== -1 && end !== -1) clean = clean.slice(start, end + 1)

    const result = JSON.parse(clean)
    return NextResponse.json({ ok: true, result })

  } catch (err: unknown) {
    const msg = err instanceof Error ? err.message : 'Unknown error'
    return NextResponse.json({ error: msg }, { status: 500 })
  }
}
